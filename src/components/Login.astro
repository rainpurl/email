<div class="auth" id="auth">
  <div class="auth-text" id="authText">you are not authorized.</div>
  <input
    id="pw"
    class="auth-input"
    type="text"
    autocomplete="off"
    autocapitalize="off"
    autocorrect="off"
    spellcheck="false"
    aria-label="authorization"
  />
</div>

<script>
  const pw = document.getElementById('pw');
  const txt = document.getElementById('authText');

  function refocus() {
    if (document.activeElement !== pw) pw.focus();
  }
  pw.focus();
  document.addEventListener('click', refocus);
  document.addEventListener('touchend', refocus, { passive: true });
  window.addEventListener('focus', refocus);

  let busy = false;
  pw.addEventListener('keydown', async (e) => {
    if (e.key !== 'Enter' || busy) return;
    e.preventDefault();
    busy = true;
    const value = pw.value;
    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: value }),
      });
      const d = await res.json();
      if (res.ok && d && d.ok) {
        location.href = '/app';
        return;
      }
    } catch {}
    pw.value = '';
    txt.classList.remove('deny');
    void txt.offsetWidth;
    txt.classList.add('deny');
    busy = false;
  });
</script>
