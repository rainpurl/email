<div class="auth" id="auth">
  <div class="auth-text" id="authText">you are not authorized.</div>
  <input
    id="pw"
    class="auth-input"
    type="text"
    autocomplete="off"
    autocapitalize="off"
    autocorrect="off"
    spellcheck="false"
    enterkeyhint="go"
    aria-label="authorization"
    autofocus
  />
</div>

<script>
  const pw = document.getElementById('pw');
  const txt = document.getElementById('authText');

  function focusPw() {
    try { pw.focus({ preventScroll: true }); } catch { pw.focus(); }
  }
  focusPw();
  // keep the (invisible) field focused so typing always lands
  document.addEventListener('pointerdown', focusPw);
  document.addEventListener('click', focusPw);
  document.addEventListener('touchend', focusPw, { passive: true });
  window.addEventListener('focus', focusPw);
  document.addEventListener('visibilitychange', () => { if (!document.hidden) focusPw(); });

  let busy = false;
  async function attempt() {
    if (busy) return;
    busy = true;
    const value = pw.value;
    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: value }),
      });
      const d = await res.json();
      if (res.ok && d && d.ok) { location.href = '/app'; return; }
    } catch {}
    pw.value = '';
    txt.classList.remove('deny');
    void txt.offsetWidth;
    txt.classList.add('deny');
    busy = false;
  }
  pw.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); attempt(); } });
</script>
